###############################################################################
# Dockerfile.prod — Porter Robot ROS 2 Jazzy Production Image
#
# Multi-stage build:
#   Stage 1 (build):   Compiles SDK + ROS 2 workspace
#   Stage 2 (runtime): Minimal ros-base image with only install/ artefacts
#
# Supports: amd64 (dev PC) + arm64 (RPi 5, Jetson)
#
# Usage:   docker compose -f docker/docker-compose.prod.yml build
#          docker compose -f docker/docker-compose.prod.yml up -d
#
# IMPORTANT: Build context must be the repo root (porter_robot/), NOT docker/.
###############################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# STAGE 1 — Build
# ═══════════════════════════════════════════════════════════════════════════════
FROM osrf/ros:jazzy-desktop AS build

# ── System build deps ────────────────────────────────────────────────────────
RUN --mount=type=cache,id=apt-build,target=/var/cache/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-numpy \
    build-essential \
    cmake \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN rosdep init 2>/dev/null || true && rosdep update --rosdistro=jazzy

# ── Build & install YDLidar SDK ──────────────────────────────────────────────
RUN git clone --depth 1 https://github.com/YDLIDAR/YDLidar-SDK.git /tmp/YDLidar-SDK && \
    mkdir -p /tmp/YDLidar-SDK/build && \
    cd /tmp/YDLidar-SDK/build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j"$(nproc)" && \
    make install && \
    ldconfig && \
    rm -rf /tmp/YDLidar-SDK

# ── Workspace ────────────────────────────────────────────────────────────────
WORKDIR /workspace

# ── Copy package manifests → rosdep install (cached layer) ───────────────────
COPY src/ydlidar_driver/package.xml                          src/ydlidar_driver/package.xml
COPY src/porter_lidar_processor/package.xml                  src/porter_lidar_processor/package.xml
COPY src/orchestration/porter_orchestrator/package.xml       src/orchestration/porter_orchestrator/package.xml
COPY src/porter_esp32_bridge/package.xml                     src/porter_esp32_bridge/package.xml
COPY src/porter_ai_assistant/package.xml                     src/porter_ai_assistant/package.xml

RUN . /opt/ros/jazzy/setup.sh && \
    rosdep install --from-paths src --ignore-src -r -y \
      --skip-keys="ament_python" 2>/dev/null || true

# ── Copy full source & build ─────────────────────────────────────────────────
COPY src/ src/

# ── Copy ESP32 common library (needed by porter_esp32_bridge) ───────────────
COPY esp32_firmware/common/ esp32_firmware/common/

RUN . /opt/ros/jazzy/setup.sh && \
    colcon build \
      --cmake-args -DCMAKE_BUILD_TYPE=Release -Wno-dev \
      --parallel-workers "$(nproc)" \
      --event-handlers console_direct+

# ═══════════════════════════════════════════════════════════════════════════════
# STAGE 2 — Runtime (minimal)
# ═══════════════════════════════════════════════════════════════════════════════
FROM ros:jazzy-ros-base AS runtime

# ── Runtime-only system deps ─────────────────────────────────────────────────
RUN --mount=type=cache,id=apt-runtime,target=/var/cache/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    python3-numpy \
    python3-venv \
    usbutils \
    && rm -rf /var/lib/apt/lists/*

# ── AI Assistant inference runtime ───────────────────────────────────────────
RUN python3 -m venv /workspace/ai_venv && \
    /workspace/ai_venv/bin/pip install --no-cache-dir \
    llama-cpp-python>=0.3.0 \
    PyYAML>=6.0 \
    psutil>=5.9.0

# ── Copy YDLidar SDK libraries (static lib is linked in, but cmake config needed) ─
COPY --from=build /usr/local/lib/libydlidar_sdk.a       /usr/local/lib/
COPY --from=build /usr/local/lib/cmake/ydlidar_sdk/     /usr/local/lib/cmake/ydlidar_sdk/
COPY --from=build /usr/local/include/src/               /usr/local/include/src/
COPY --from=build /usr/local/include/core/              /usr/local/include/core/
RUN ldconfig

# ── Copy built workspace ────────────────────────────────────────────────────
WORKDIR /workspace
COPY --from=build /workspace/install/ install/

# ── Copy source for launch files, configs, URDF that reference share dirs ───
COPY src/ src/

# ── Copy AI data files (system prompts, tool schemas, knowledge base) ────────
COPY src/porter_ai_assistant/data/system_prompts.yaml    src/porter_ai_assistant/data/system_prompts.yaml
COPY src/porter_ai_assistant/data/tool_schemas.json      src/porter_ai_assistant/data/tool_schemas.json
COPY src/porter_ai_assistant/data/knowledge_base/        src/porter_ai_assistant/data/knowledge_base/

# ── AI GGUF models (baked into image for self-contained deployment) ──────────
COPY src/porter_ai_assistant/models/gguf/ src/porter_ai_assistant/models/gguf/

# ── Entrypoint ──────────────────────────────────────────────────────────────
COPY docker/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENV ROS_DOMAIN_ID=11
ENV RMW_IMPLEMENTATION=rmw_fastrtps_cpp

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["ros2", "launch", "ydlidar_driver", "ydlidar_launch.py"]