# Porter Robot — ESP32 USB Device Stable Naming Rules
#
# Creates stable symlinks for ESP32 devices connected via USB serial:
#   /dev/esp32_motors  → ESP32 #1 (motor controller)
#   /dev/esp32_sensors → ESP32 #2 (sensor fusion)
#
# Matching strategy:
#   Option A: Match by USB serial number (preferred — unique per device)
#   Option B: Match by USB port path (physical port on hub)
#
# ============================================================================
# STEP 1: Find your device identifiers
# ============================================================================
# Plug in ONE ESP32 at a time and run:
#   udevadm info -a -n /dev/ttyUSB0 | grep -E 'serial|idVendor|idProduct|KERNELS'
#
# For CP2102 (common on ESP32-WROOM DevKit):
#   idVendor  = "10c4"
#   idProduct = "ea60"
#   serial    = "<unique serial>"
#
# For CH340 (common on NodeMCU/cheap boards):
#   idVendor  = "1a86"
#   idProduct = "7523"
#   serial    = (usually empty — use port path instead)
#
# For ESP32-S2/S3 native USB CDC ACM:
#   idVendor  = "303a" (Espressif)
#   idProduct = "1001" (ESP32-S2) or "1001" (ESP32-S3)
#
# ============================================================================
# OPTION A: Match by serial number (recommended when available)
# ============================================================================
# Replace SERIAL_MOTOR and SERIAL_SENSOR with actual values from udevadm

# ESP32 #1 — Motor Controller (CP2102)
# SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="SERIAL_MOTOR", SYMLINK+="esp32_motors", MODE="0666"

# ESP32 #2 — Sensor Fusion (CP2102)
# SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="SERIAL_SENSOR", SYMLINK+="esp32_sensors", MODE="0666"

# ============================================================================
# OPTION B: Match by USB port path (when serial numbers are unavailable)
# ============================================================================
# Use 'udevadm info -a -n /dev/ttyUSB0 | grep KERNELS' to find the port path.
# The KERNELS value looks like "1-1.2:1.0" — it's stable as long as you don't
# move the device to a different physical USB port.
#
# Example: RPi USB port 1 → motor, RPi USB port 2 → sensor
# SUBSYSTEM=="tty", KERNELS=="1-1.2:1.0", SYMLINK+="esp32_motors", MODE="0666"
# SUBSYSTEM=="tty", KERNELS=="1-1.3:1.0", SYMLINK+="esp32_sensors", MODE="0666"

# ============================================================================
# YDLIDAR (for reference — already handled by ydlidar_driver)
# ============================================================================
# SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="SERIAL_LIDAR", SYMLINK+="ydlidar", MODE="0666"

# ============================================================================
# Generic fallback: give all ttyUSB/ttyACM devices rw permission
# ============================================================================
SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", MODE="0666"
SUBSYSTEM=="tty", KERNEL=="ttyACM[0-9]*", MODE="0666"
